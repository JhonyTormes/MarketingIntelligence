## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# StyleCop
StyleCopReport.xml

# FxCop
FxCopReport.xml

# Service Fabric Backup files
**/*_backup_*.bak

# Client-side Build Output
node_modules/
bower_components/

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Management patterns
packages/
*.nuget.props
*.nuget.targets

# Model dependencies
.model/

# TextTransform files
*.txt.tmp

# Property file adjustments
*.props
*.targets

# JetBrains Rider
.idea/
*.sln.iml

# Microsoft Visual Studio Code
.vscode/

# User Secrets
# This file contains the local user secrets (connection strings, passwords, etc)
# It is important to ignore it, even though it is usually stored outside the project folder
# Just in case someone copies it locally.
secrets.json

# AppSettings
# NEVER commit appsettings.local.json or appsettings.Development.json IF it contains secrets
# In our project we sanitized appsettings.json, but it is good practice to ignore local overrides
appsettings.local.json
appsettings.Development.json

# Temporary files
*.tmp
*.log

